# Clash of Clans MCP Server config
# Get a token at https://developer.clashofclans.com (free, IP-whitelisted)
COC_API_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGc...

# Optional: default clan tag (you can still pass one per-call)
# Format with or without leading # — both work
COC_DEFAULT_CLAN_TAG=#YV9JRULU

# Optional: path to a custom rubric JSON. Defaults to config/rubric.default.json
# COC_RUBRIC_PATH=./config/rubric.local.json
